# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Ensure specific file types use LF
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.xml text eol=lf
*.sh text eol=lf
*.conf text eol=lf
*.env text eol=lf
*.env.* text eol=lf

# Ensure Windows-specific files use CRLF if needed
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files (do not modify)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
